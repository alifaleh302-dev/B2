# Copy this file to .env locally (or set these as environment variables on Render)
# v4 — Hydra Seat Engine

# ─── Telegram (REQUIRED — secrets, keep on Render only) ───────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# Optional: comma-separated extra chat IDs allowed to use the bot
# AUTHORIZED_CHAT_IDS=11111,22222

# ─── Server ──────────────────────────────────────────────────────────
PORT=10000
# Render sets RENDER_EXTERNAL_URL automatically; otherwise set:
# PUBLIC_URL=https://your-app.onrender.com

# ─── Database (REQUIRED for persistent storage) ──────────────────────
# Render PostgreSQL connection string
DATABASE_URL=postgresql://user:pass@host/db
# Optional Turso fallback
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=

# ─── Monitor tuning ──────────────────────────────────────────────────
EVENT_POLL_INTERVAL=300
# (legacy SNIPER_POLL_INTERVAL removed in v4 — drop watcher is event-driven)

# ─── Keep-alive (anti-sleep on Render free tier) ─────────────────────
KEEP_ALIVE_ENABLED=true
KEEP_ALIVE_INTERVAL=600

# ─── Proxy / paid reliability ────────────────────────────────────────
USE_PROXY=false
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
# 2Captcha key — used for both reCAPTCHA v3 (login) AND Cloudflare
# Turnstile (booking hold-token).
CAPTCHA_API_KEY=
USE_STEALTH_BROWSER=true

# ─── Cloudflare Turnstile auto-solve ─────────────────────────────────
# Master switch for automatic Turnstile solving via 2Captcha. When set
# to false, the booking flow falls back to Playwright on `turnstile_required`.
TURNSTILE_SOLVER_ENABLED=true
# Total seconds 2Captcha is allowed to spend on each Turnstile token.
TURNSTILE_SOLVER_TIMEOUT=180
# Override the public Turnstile sitekey discovered on webook.com if it
# changes. Default is shipped in app/core/config.py.
# WEBOOK_TURNSTILE_SITEKEY=0x4AAAAAAAh8wjF6lP6t-zEC

# ─── Seats.io / SeatCloud (Hydra Engine) ─────────────────────────────
SEATSIO_ENABLED=true
SEATSIO_PREWARM_ENABLED=true
SEATSIO_TOKEN_TTL=3600
SEATSIO_STATUS_INTERVAL=0.60
SEATSIO_DROP_WATCHER_ENABLED=true
SEATSIO_DROP_WATCHER_MAX_WAIT=1800

# Legacy global block fallback. New flow uses per-event block picker
# from the Telegram bot, so leave this empty in production.
TARGET_BLOCKS=

# ─── Payment ─────────────────────────────────────────────────────────
# Default unified payment for ALL accounts. Allowed: credit_card | apple_pay
# Can also be changed live from the bot's Settings menu.
DEFAULT_PAYMENT_METHOD=credit_card

# ─── Browser ─────────────────────────────────────────────────────────
HEADLESS=true

# ─── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Admin UI ────────────────────────────────────────────────────────
ADMIN_PASSWORD=webook-admin
