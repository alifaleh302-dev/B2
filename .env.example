# Copy this file to .env locally (or set these as environment variables on Render)

# ─── Telegram (required) ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# Optional: comma-separated extra chat IDs allowed to use the bot
# AUTHORIZED_CHAT_IDS=11111,22222

# ─── Server ──────────────────────────────────────────────────────────
PORT=10000
# Render sets RENDER_EXTERNAL_URL automatically; otherwise:
# PUBLIC_URL=https://your-app.onrender.com

# ─── Monitor tuning ──────────────────────────────────────────────────
POLL_INTERVAL=1.5
MAX_ATTEMPTS=0        # 0 = infinite (true 24/7 monitoring)

# ─── Keep-alive (anti-sleep on Render free tier) ─────────────────────
KEEP_ALIVE_ENABLED=true
KEEP_ALIVE_INTERVAL=600

# ─── Proxy / paid reliability ────────────────────────────────────────
USE_PROXY=false
AUTO_FETCH_PROXIES=true
PROXY_REFRESH_INTERVAL=1800
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
CAPTCHA_API_KEY=
USE_STEALTH_BROWSER=true

# ─── Seats.io / SeatCloud ────────────────────────────────────────────
SEATSIO_ENABLED=true
SEATSIO_PREWARM_ENABLED=true
SEATSIO_TOKEN_TTL=3600
SEATSIO_STATUS_INTERVAL=0.60
SEATSIO_STALKER_ENABLED=true
SEATSIO_STALKER_MAX_WAIT=45
SEATSIO_STALKER_POLL_INTERVAL=0.50
TARGET_BLOCKS=

# ─── Browser ─────────────────────────────────────────────────────────
HEADLESS=true

# ─── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
